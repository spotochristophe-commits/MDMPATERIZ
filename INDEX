</div>

<!-- ══ INFO BAR ═════════════════════════════════════════════ -->
<div class="info-bar">
  <span>📅 Catalogue 2026</span>
  <span>📦 Remise dès 10 colis</span>
  <span>🌿 Certifiés Agriculture Biologique AB</span>
