</div>

<!-- ══ STICKY TOTAL ═════════════════════════════════════════ -->
<div class="sticky-total">
  <div class="totals">
    <div class="t-item">
      <div class="t-label">Nb Colis</div>
      <div class="t-value" id="st-colis">0</div>
