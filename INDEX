<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Moulin des Moines — Bon de Commande Épicerie Bio 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --terra:    #C87864;
  --terra-d:  #A05A48;
  --terra-l:  #F2D4CC;
  --brown:    #78503C;
  --brown-l:  #9E6A52;
  --cream:    #FDF5EE;
  --cream-d:  #F0E0D0;
  --gold:     #D2B469;
  --gold-l:   #F5E8C4;
  --green:    #1A5C2E;
  --green-l:  #EAF4EC;
  --text:     #2C1A10;
  --muted:    #8A6A5A;
  --white:    #FFFFFF;
  --shadow:   0 4px 24px rgba(120,80,60,0.10);
  --shadow-lg:0 8px 40px rgba(120,80,60,0.16);
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Outfit',sans-serif;background:var(--cream);color:var(--text);min-height:100vh;}

/* ══ HEADER ═════════════════════════════════════════════════ */
header{background:var(--brown);position:relative;overflow:hidden;}
header::before{
  content:'';position:absolute;inset:0;
  background:repeating-linear-gradient(45deg,transparent,transparent 30px,rgba(255,255,255,0.02) 30px,rgba(255,255,255,0.02) 60px);
}
.header-inner{
  max-width:1100px;margin:0 auto;padding:32px 24px 24px;
  position:relative;z-index:1;
  display:flex;align-items:flex-end;justify-content:space-between;gap:20px;flex-wrap:wrap;
}
.brand{display:flex;flex-direction:column;gap:6px;}
.brand-name{font-family:'Cormorant Garamond',serif;font-size:2.4rem;font-weight:700;color:var(--white);line-height:1.1;letter-spacing:.01em;}
.brand-sub{font-size:.75rem;font-weight:300;color:rgba(255,255,255,.65);letter-spacing:.12em;text-transform:uppercase;}
.header-right{display:flex;flex-direction:column;align-items:flex-end;gap:8px;}
.promo-pill{
  background:var(--terra);color:var(--white);padding:10px 22px;border-radius:50px;
  font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:600;
  display:flex;align-items:center;gap:10px;box-shadow:0 4px 20px rgba(0,0,0,.25);white-space:nowrap;
}
.promo-pill .pct{font-size:1.5rem;color:var(--gold);}
.gold-line{height:3px;background:linear-gradient(90deg,var(--terra),var(--gold),var(--terra-l),var(--gold));}

/* ══ PALIERS ════════════════════════════════════════════════ */
.paliers-section{
  background:var(--cream);border-bottom:2px solid var(--cream-d);
  padding:16px 24px;
}
.paliers-inner{max-width:1100px;margin:0 auto;}
.paliers-label{
  font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:600;
  color:var(--brown);margin-bottom:10px;display:flex;align-items:center;gap:8px;
}
.paliers-label::before{content:'';width:4px;height:16px;background:var(--gold);border-radius:3px;}
.paliers-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:8px;}
.palier{
  border-radius:10px;padding:12px;border:2px solid transparent;
  position:relative;overflow:hidden;transition:all .3s;
}
.pal-0{background:#f5f0eb;border-color:#d8c8b8;}
.pal-1{background:#fffbf0;border-color:#d2b469;}
.pal-2{background:#f0f6ff;border-color:#6fa8d2;}
.pal-3{background:var(--green-l);border-color:#1a5c2e;}
.palier.active{transform:translateY(-2px);}
.pal-0.active{box-shadow:0 6px 18px rgba(0,0,0,.1);}
.pal-1.active{box-shadow:0 6px 18px rgba(210,180,105,.3);}
.pal-2.active{box-shadow:0 6px 18px rgba(111,168,210,.25);}
.pal-3.active{box-shadow:0 6px 18px rgba(26,92,46,.2);}
.pal-badge{
  position:absolute;top:6px;right:6px;font-size:.55rem;font-weight:700;
  padding:2px 6px;border-radius:20px;text-transform:uppercase;letter-spacing:.06em;
  opacity:0;transition:opacity .3s;
}
.palier.active .pal-badge{opacity:1;}
.pal-1 .pal-badge{background:var(--gold);color:var(--brown);}
.pal-2 .pal-badge{background:#2980b9;color:#fff;}
.pal-3 .pal-badge{background:var(--green);color:#fff;}
.pal-0 .pal-badge{background:var(--muted);color:#fff;}
.pal-icon{font-size:1.2rem;margin-bottom:4px;}
.pal-pct{font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:700;line-height:1;margin-bottom:2px;}
.pal-0 .pal-pct{color:var(--muted);}
.pal-1 .pal-pct{color:#b8941a;}
.pal-2 .pal-pct{color:#2980b9;}
.pal-3 .pal-pct{color:var(--green);}
.pal-name{font-size:.68rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px;}
.pal-0 .pal-name{color:var(--muted);}
.pal-1 .pal-name{color:#9a7010;}
.pal-2 .pal-name{color:#1a608a;}
.pal-3 .pal-name{color:var(--green);}
.pal-seuil{font-size:.7rem;font-weight:400;}
.pal-0 .pal-seuil{color:var(--muted);}
.pal-1 .pal-seuil{color:#9a7010;}
.pal-2 .pal-seuil{color:#1a608a;}
.pal-3 .pal-seuil{color:var(--green);}
.progress-wrap{background:var(--cream-d);border-radius:20px;height:6px;margin:6px 0 3px;overflow:hidden;}
.progress-fill{height:100%;border-radius:20px;background:linear-gradient(90deg,var(--gold),var(--green));transition:width .5s cubic-bezier(.34,1.56,.64,1);width:0%;}
.progress-txt{font-size:.68rem;color:var(--muted);text-align:right;}

/* ══ INFO BAR ═══════════════════════════════════════════════ */
.info-bar{
  background:var(--green-l);border-bottom:2px solid var(--green);
  padding:10px 24px;display:flex;align-items:center;justify-content:center;
  gap:32px;flex-wrap:wrap;font-size:.82rem;color:var(--green);font-weight:500;
}
.info-bar span{display:flex;align-items:center;gap:6px;}

/* ══ STICKY ═════════════════════════════════════════════════ */
.sticky-total{
  position:sticky;top:0;z-index:100;background:var(--brown);color:var(--white);
  padding:12px 24px;display:flex;align-items:center;justify-content:space-between;
  gap:16px;flex-wrap:wrap;box-shadow:0 4px 20px rgba(0,0,0,.2);
  border-radius:0 0 12px 12px;
}
.sticky-total .totals{display:flex;gap:28px;align-items:center;flex-wrap:wrap;}
.t-item{display:flex;flex-direction:column;gap:1px;}
.t-label{font-size:.68rem;opacity:.65;text-transform:uppercase;letter-spacing:.08em;}
.t-value{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:700;color:var(--gold);}
.t-value.warn{color:#F4A261;}
.t-value.ok{color:#6FCF97;}
.remise-tag{
  font-size:.78rem;padding:5px 14px;border-radius:20px;font-weight:600;
  background:rgba(255,255,255,.12);color:rgba(255,255,255,.75);
  border:1px solid rgba(255,255,255,.15);transition:all .3s;white-space:nowrap;
}
.remise-tag.p1{background:rgba(210,180,105,.25);color:var(--gold-l);border-color:rgba(210,180,105,.4);}
.remise-tag.p2{background:rgba(41,128,185,.25);color:#7ec8f5;border-color:rgba(41,128,185,.4);}
.remise-tag.p3{background:rgba(26,92,46,.3);color:#6FCF97;border-color:rgba(26,92,46,.5);}

/* ══ MAIN ════════════════════════════════════════════════════ */
main{max-width:1100px;margin:0 auto;padding:28px 24px 80px;}
.section-title{
  font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:600;
  color:var(--brown);margin-bottom:14px;padding-bottom:8px;
  border-bottom:2px solid var(--terra-l);display:flex;align-items:center;gap:10px;
}
.section-title::before{content:'';width:5px;height:20px;background:var(--terra);border-radius:3px;flex-shrink:0;}

/* ══ GAMME BLOCK ════════════════════════════════════════════ */
.gamme-block{
  background:var(--white);border-radius:14px;overflow:hidden;margin-bottom:20px;
  box-shadow:var(--shadow);border:1px solid var(--cream-d);animation:slideUp .5s ease both;
}
@keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}
.gamme-block:nth-child(1){animation-delay:.05s}
.gamme-block:nth-child(2){animation-delay:.10s}
.gamme-block:nth-child(3){animation-delay:.15s}
.gamme-block:nth-child(4){animation-delay:.20s}
.gamme-block:nth-child(5){animation-delay:.25s}
.gamme-header{
  background:var(--brown);padding:12px 18px;
  display:flex;align-items:center;gap:10px;
  font-weight:600;font-size:.88rem;color:var(--white);letter-spacing:.02em;
}
.gamme-count{
  margin-left:auto;font-size:.7rem;background:rgba(255,255,255,.15);
  padding:2px 9px;border-radius:20px;font-weight:400;
}

/* ══ TABLE EN-TÊTE ══════════════════════════════════════════ */
.table-head{
  display:grid;
  grid-template-columns: 1fr 100px 110px 65px 80px 85px 120px 90px;
  padding:8px 16px;background:var(--cream);border-bottom:1px solid var(--cream-d);
  font-size:.67rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;gap:6px;
}
.tc{text-align:center;}.tr{text-align:right;}

/* ══ PRODUCT ROW ════════════════════════════════════════════ */
.product-row{
  display:grid;
  grid-template-columns: 1fr 100px 110px 65px 80px 85px 120px 90px;
  align-items:center;padding:9px 16px;gap:6px;
  border-bottom:1px solid var(--cream-d);transition:background .15s;
}
.product-row:last-child{border-bottom:none;}
.product-row:hover{background:#FEFAF6;}
.product-row:nth-child(even){background:#FAF7F3;}
.product-row:nth-child(even):hover{background:#FEFAF6;}

.prod-name{font-size:.83rem;font-weight:500;color:var(--text);line-height:1.3;}
.prod-ean{font-size:.65rem;color:var(--muted);font-family:monospace;letter-spacing:.02em;}
.prod-ref{font-size:.7rem;color:var(--muted);font-style:italic;}
.prod-format{font-size:.78rem;color:var(--muted);text-align:center;}
.prod-prix-ht{font-size:.8rem;color:var(--muted);text-align:right;text-decoration:line-through;text-decoration-color:var(--terra-l);}
.prod-prix-promo{font-size:.86rem;font-weight:700;text-align:right;color:var(--muted);transition:color .3s;}
.prod-unites{font-size:.75rem;font-weight:600;color:var(--muted);text-align:right;transition:color .3s;min-width:0;}

/* Saisie colis */
.colis-input-wrap{
  display:flex;align-items:center;border:1.5px solid var(--gold);border-radius:7px;
  overflow:hidden;background:var(--white);box-shadow:0 1px 5px rgba(210,180,105,.15);
}
.colis-btn{
  width:24px;height:30px;background:var(--gold-l);border:none;cursor:pointer;
  font-size:.95rem;font-weight:700;color:var(--brown);
  display:flex;align-items:center;justify-content:center;transition:background .15s;flex-shrink:0;
}
.colis-btn:hover{background:var(--gold);}
.colis-input{
  width:100%;height:30px;border:none;text-align:center;
  font-family:'Outfit',sans-serif;font-size:.88rem;font-weight:700;color:var(--brown);
  background:transparent;outline:none;min-width:0;
}
.colis-input::-webkit-inner-spin-button,.colis-input::-webkit-outer-spin-button{-webkit-appearance:none;}
.colis-input[type=number]{-moz-appearance:textfield;}

/* Tag VRAC */
.tag-vrac{
  font-size:.6rem;font-weight:700;background:var(--terra-l);color:var(--terra-d);
  padding:1px 6px;border-radius:4px;margin-left:5px;vertical-align:middle;
}
.tag-sg{
  font-size:.6rem;font-weight:700;background:#e8f5ee;color:var(--green);
  padding:1px 6px;border-radius:4px;margin-left:5px;vertical-align:middle;
}
.tag-lac{
  font-size:.6rem;font-weight:700;background:#e8f0ff;color:#5046a0;
  padding:1px 6px;border-radius:4px;margin-left:5px;vertical-align:middle;
}

/* ══ RÉCAP ══════════════════════════════════════════════════ */
.recap-bar{
  display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:28px;
}
.recap-item{
  background:var(--brown);border-radius:12px;padding:16px 18px;text-align:center;
  box-shadow:0 4px 16px rgba(120,80,60,.12);
}
.recap-item.orange{background:var(--terra);}
.recap-item.brown2{background:var(--brown-l);}
.recap-label{font-size:.66rem;color:rgba(255,255,255,.55);text-transform:uppercase;letter-spacing:.1em;margin-bottom:4px;}
.recap-value{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:700;color:var(--gold-l);line-height:1;}
.recap-value.small{font-size:1.2rem;}
.recap-value.warn{color:#F4A261;}
.recap-value.ok{color:#6FCF97;}
.recap-sub{font-size:.63rem;color:rgba(255,255,255,.35);margin-top:3px;}

/* ══ FORMULAIRE ═════════════════════════════════════════════ */
.client-card{
  background:var(--white);border-radius:14px;padding:24px;
  border:1px solid var(--cream-d);box-shadow:var(--shadow);margin-bottom:22px;
}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:14px;}
.field label{display:block;font-size:.7rem;font-weight:600;color:var(--brown-l);text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px;}
.field input{
  width:100%;padding:10px 13px;border:1.5px solid var(--cream-d);border-radius:8px;
  font-family:'Outfit',sans-serif;font-size:.88rem;color:var(--text);
  background:var(--cream);outline:none;transition:all .2s;
}
.field input:focus{border-color:var(--terra);box-shadow:0 0 0 3px rgba(200,120,100,.13);background:var(--white);}
.req{color:var(--terra);}

/* ══ BOUTONS ════════════════════════════════════════════════ */
.btn-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:22px;}
.btn{
  padding:14px 20px;border:none;border-radius:10px;
  font-family:'Outfit',sans-serif;font-size:.9rem;font-weight:600;cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:9px;transition:all .2s;
}
.btn-pdf{background:var(--brown);color:var(--white);box-shadow:0 4px 14px rgba(120,80,60,.25);}
.btn-pdf:hover{background:var(--brown-l);transform:translateY(-1px);}
.btn-send{background:var(--terra);color:var(--white);box-shadow:0 4px 14px rgba(200,120,100,.3);}
.btn-send:hover{background:var(--terra-d);transform:translateY(-1px);}
.btn:active{transform:translateY(0)!important;}
.btn:disabled{opacity:.6;cursor:not-allowed;transform:none!important;}

/* ══ SUCCESS ════════════════════════════════════════════════ */
#success-msg{
  display:none;background:var(--green-l);border:2px solid var(--green);
  border-radius:14px;padding:24px 28px;text-align:center;animation:slideUp .4s ease;
}
#success-msg h3{font-family:'Cormorant Garamond',serif;font-size:1.4rem;color:var(--green);margin-bottom:8px;}
#success-msg p{font-size:.88rem;color:var(--green);}
#order-recap{
  margin-top:16px;text-align:left;background:var(--white);border-radius:8px;padding:14px;
  font-size:.72rem;color:var(--text);white-space:pre-wrap;font-family:'Courier New',monospace;
  border:1px solid var(--cream-d);max-height:260px;overflow-y:auto;
}

/* ══ FOOTER ═════════════════════════════════════════════════ */
footer{
  text-align:center;padding:14px 24px;font-size:.76rem;color:var(--muted);
  border-top:1px solid var(--cream-d);background:var(--white);
}

/* ══ RESPONSIVE ═════════════════════════════════════════════ */
@media(max-width:760px){
  .paliers-grid{grid-template-columns:1fr 1fr;}
  .table-head{display:none;}
  .product-row{grid-template-columns:1fr auto;grid-template-rows:auto auto auto;}
  .prod-ean,.prod-prix-ht,.prod-format{display:none;}
  .recap-bar{grid-template-columns:1fr 1fr;}
  .btn-row{grid-template-columns:1fr;}
  .form-grid{grid-template-columns:1fr;}
  .header-inner{flex-direction:column;}
  .brand-name{font-size:1.7rem;}
}
@media print{
  .sticky-total,.btn-row,#success-msg,.paliers-section{display:none!important;}
  body{background:#fff;}main{padding:0;}
}
</style>
</head>
<body>

<!-- ══ HEADER ══════════════════════════════════════════════ -->
<header>
