    </div>
  </div>
  <div class="remise-tag" id="remise-tag">🏷️ Aucune remise active</div>
</div>

<!-- ══ MAIN ══════════════════════════════════════════════════ -->
<main>
  <div class="section-title" style="margin-top:4px">Épicerie Bio — Catalogue 2026</div>

  <!-- ── 5.1 PÂTES À L'ÉPEAUTRE ───────────────────────────── -->
  <div class="gamme-block">
    <div class="gamme-header">🌾 5.1 — Pâtes à l'Épeautre <span class="gamme-count">4 références</span></div>
    <div class="table-head">
