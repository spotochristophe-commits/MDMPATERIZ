<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
// ═══════════════════════════════════════════════════════════
// PALIERS DE REMISE
// ═══════════════════════════════════════════════════════════
const PALIERS = [
  { seuil:  0, remise: 0,    label: 'Aucune remise',  tag: '🏷️ Aucune remise active',         tagClass: '',   palId: 'pal-0' },
  { seuil: 10, remise: 0.07, label: '−7% Bronze',     tag: '⭐ Remise −7% appliquée',          tagClass: 'p1', palId: 'pal-1' },
  { seuil: 15, remise: 0.10, label: '−10% Argent',    tag: '💎 Remise −10% appliquée',         tagClass: 'p2', palId: 'pal-2' },
  { seuil: 20, remise: 0.12, label: '−12% Or',        tag: '🏆 Remise −12% appliquée',         tagClass: 'p3', palId: 'pal-3' },
];

function getPalier(n) {
  let p = PALIERS[0];
  for (const x of PALIERS) { if (n >= x.seuil) p = x; }
  return p;
}
function getNext(n) {
  for (const x of PALIERS) { if (x.seuil > n) return x; }
  return null;
}

// ── +/- boutons ──────────────────────────────────────────────
function adj(btn, d) {
  const inp = btn.parentElement.querySelector('.colis-input');
  inp.value = Math.max(0, (parseInt(inp.value)||0) + d);
  recalc();
}

// ── Recalcul global ──────────────────────────────────────────
function recalc() {
  let totalColis = 0, totalUnites = 0, htBrut = 0;

  document.querySelectorAll('.product-row').forEach(row => {
    const colis = parseInt(row.querySelector('.colis-input').value)||0;
    const pcb   = parseInt(row.dataset.pcb)||1;
    const prix  = parseFloat(row.dataset.price)||0;
    totalColis  += colis;
    totalUnites += colis * pcb;
    htBrut      += prix * pcb * colis;
  });

  const palier = getPalier(totalColis);
  const remise = palier.remise;
  const ht  = htBrut * (1 - remise);
  const tva = ht * 0.055;
  const ttc = ht + tva;
  const next = getNext(totalColis);

  const fmt = v => v.toFixed(2).replace('.', ',') + ' €';

  // Prix promo ligne par ligne
  document.querySelectorAll('.product-row').forEach(row => {
    const colis  = parseInt(row.querySelector('.colis-input').value)||0;
    const pcb    = parseInt(row.dataset.pcb)||1;
    const prix   = parseFloat(row.dataset.price)||0;
    const promoEl = row.querySelector('.prod-prix-promo');
    const unitEl  = row.querySelector('.prod-unites');

    if (remise > 0) {
      promoEl.textContent = fmt(prix * (1 - remise));
      promoEl.style.color = palier.seuil===10 ? '#b8941a' : palier.seuil===15 ? '#2980b9' : 'var(--green)';
    } else {
      promoEl.textContent = '—';
      promoEl.style.color = 'var(--muted)';
    }

    const nbU = colis * pcb;
    if (colis > 0) {
      const lineHT = prix * (1 - remise) * pcb * colis;
      unitEl.textContent = nbU + ' u — ' + fmt(lineHT);
      unitEl.style.color = 'var(--green)';
    } else {
      unitEl.textContent = '—';
      unitEl.style.color = 'var(--muted)';
    }
  });

  // Sticky
  const stc = document.getElementById('st-colis');
  stc.textContent = totalColis;
  stc.className = 't-value ' + (totalColis===0 ? '' : remise>0 ? 'ok' : 'warn');
  document.getElementById('st-unites').textContent = totalUnites;
  document.getElementById('st-total').textContent  = fmt(ht);
  document.getElementById('st-tva').textContent    = fmt(tva);
  document.getElementById('st-ttc').textContent    = fmt(ttc);

  const tag = document.getElementById('remise-tag');
  tag.textContent = palier.tag;
  tag.className   = 'remise-tag ' + palier.tagClass;

  // Badge header
  document.getElementById('badge-pct').textContent = remise > 0
    ? '−' + Math.round(remise*100) + '% appliqué'
    : 'Remise progressive';

  // Paliers visuels
  PALIERS.forEach(p => {
    const el = document.getElementById(p.palId);
    if (el) el.classList.toggle('active', p === palier);
  });

  // Progression
  const fill = document.getElementById('progress-fill');
  const ptxt = document.getElementById('progress-txt');
  if (!next) {
    fill.style.width = '100%';
    ptxt.textContent = '🏆 Palier Or — remise maximale −12% active !';
    ptxt.style.color = 'var(--green)';
  } else {
    const prev  = PALIERS[PALIERS.indexOf(next)-1];
    const range = next.seuil - (prev ? prev.seuil : 0);
    const done  = totalColis - (prev ? prev.seuil : 0);
    fill.style.width = Math.min(100, Math.round((done/range)*100)) + '%';
    const manque = next.seuil - totalColis;
    ptxt.textContent = manque <= 0 ? 'Palier atteint !'
      : 'Encore ' + manque + ' colis pour débloquer −' + Math.round(next.remise*100) + '%';
    ptxt.style.color = '';
  }

  // Récap
  const rc = document.getElementById('r-colis');
  rc.textContent = totalColis;
  rc.className = 'recap-value ' + (totalColis===0 ? '' : remise>0 ? 'ok' : 'warn');

  const rem = document.getElementById('r-remise');
  rem.textContent = remise > 0 ? '−'+Math.round(remise*100)+'%' : '—';
  rem.style.color = remise > 0 ? 'var(--gold-l)' : 'rgba(255,255,255,.3)';
  document.getElementById('r-remise-sub').textContent = palier.label;
  document.getElementById('r-total').textContent = fmt(ht);
  document.getElementById('r-ht-sub').textContent = remise > 0 ? 'après '+palier.label : 'prix catalogue';
  document.getElementById('r-ttc').textContent = fmt(ttc);
}

function fmt(v){ return v.toFixed(2).replace('.', ',') + ' €'; }
function vv(id){ return document.getElementById(id).value.trim(); }

// ── Construire le récapitulatif ──────────────────────────────
function buildRecap() {
  const societe = vv('f-societe') || '—';
  const email   = vv('f-email')   || '—';
  const date    = new Date().toLocaleDateString('fr-FR',{day:'2-digit',month:'long',year:'numeric'});

  let lines = [], totalColis = 0, totalUnites = 0, htBrut = 0;
  document.querySelectorAll('.product-row').forEach(row => {
    const colis = parseInt(row.querySelector('.colis-input').value)||0;
    if (!colis) return;
    const pcb   = parseInt(row.dataset.pcb)||1;
    const prix  = parseFloat(row.dataset.price)||0;
    const name  = row.querySelector('.prod-name').textContent.trim();
    const ref   = row.querySelector('.prod-ref').textContent.trim();
    const fmt_p = row.querySelector('.prod-format').textContent.trim();
    const nbU   = colis * pcb;
    totalColis  += colis;
    totalUnites += nbU;
    htBrut      += prix * pcb * colis;
    lines.push('  • ['+ref+'] '+name+' ('+fmt_p+') — '+colis+' colis / '+nbU+' unités');
  });

  const palier = getPalier(totalColis);
  const ht  = htBrut * (1 - palier.remise);
  const tva = ht * 0.055;
  const ttc = ht + tva;
  const fmt = v => v.toFixed(2).replace('.',',')+' €';

  return [
    '═══════════════════════════════════════════════════',
    'BON DE COMMANDE — ÉPICERIE BIO 2026',
    'Moulin des Moines — Catalogue 2026',
    '═══════════════════════════════════════════════════',
    '',
    'CLIENT',
    '  Magasin  : ' + societe,
    '  Email    : ' + email,
    '  Date     : ' + date,
    '',
    'PRODUITS COMMANDÉS',
    ...lines,
    '───────────────────────────────────────────────────',
    '  Nb colis       : ' + totalColis,
    '  Nb unités      : ' + totalUnites,
    '  Total HT brut  : ' + fmt(htBrut),
    '  Remise         : ' + palier.label + ' (' + Math.round(palier.remise*100) + '%)',
    '  Total HT       : ' + fmt(ht),
    '  TVA 5,5%       : ' + fmt(tva),
    '  TOTAL TTC      : ' + fmt(ttc),
    '═══════════════════════════════════════════════════',
  ].join('\n');
}

// ── Envoyer la commande ──────────────────────────────────────
async function envoyerCommande() {
  const societe = vv('f-societe');
  const email   = vv('f-email');
  if (!societe || !email) { alert('Merci de renseigner le nom de votre magasin et votre email.'); return; }

  let totalColis = 0;
  document.querySelectorAll('.colis-input').forEach(i => totalColis += parseInt(i.value)||0);
  if (totalColis === 0) { alert('Veuillez sélectionner au moins 1 colis avant d\'envoyer.'); return; }

  const recap = buildRecap();
  document.getElementById('order-recap').textContent = recap;

  const btn = document.getElementById('btn-send');
  btn.textContent = '⏳ Envoi en cours...';
  btn.disabled = true;

  try {
    const response = await fetch('https://formsubmit.co/ajax/cspoto@moulindesmoines.com', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({
        _subject:     'Commande Épicerie Bio — ' + societe + ' — ' + new Date().toLocaleDateString('fr-FR'),
        _template:    'box',
        _captcha:     'false',
        magasin:      societe,
        email_client: email,
        remise:       getPalier(totalColis).label,
        commande:     recap
      })
    });
    const result = await response.json();
    if (result.success === 'true' || result.success === true) {
      btn.textContent = '✅ Commande envoyée !';
      const s = document.getElementById('success-msg');
      s.styl
