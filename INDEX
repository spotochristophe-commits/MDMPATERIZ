    <div class="paliers-label">🎯 Paliers de remise — Pâtes &amp; Spécialités Bio 2026</div>
    <div class="paliers-grid">
      <div class="palier pal-0 active" id="pal-0">
        <div class="pal-badge">En cours</div>
        <div class="pal-icon">🛒</div>
