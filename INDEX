    <div class="product-row" data-price="2.75" data-pcb="12">
      <div class="prod-name">Penne d'épeautre* bio</div>
      <div class="prod-ean">3547430030046</div>
      <div class="prod-ref">PENEPE</div>
      <div class="prod-format">500 g</div>
